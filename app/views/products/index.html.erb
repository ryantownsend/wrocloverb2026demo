<div class="flex flex-col gap-5 items-stretch w-full max-w-200 p-5 bg-slate-100 rounded-md">
  <h1 class="text-xl text-left font-semibold">Products</h1>

  <table>
    <%= render "sort_options" %>

    <?start name="products">
    <tbody class="text-gray-300">
      <% 5.times do %>
      <tr>
        <th>Loading&hellip;</th>
        <td>$0.00</td>
        <td>0</td>
        <td>N/A</td>
        <td><button type="button" disabled>Edit</button></td>
      </tr>
      <% end %>
    </tbody>
    <?end name="products">
  </table>
</div>

<?marker name="product-dialogs">

<%= render "products" %>
<%= render "product_dialogs" %>
